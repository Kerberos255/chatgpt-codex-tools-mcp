# chatgpt-codex-tools-mcp — environment variable config
# Copy this to .env and adapt locally. Do not publish the .env file.

HOST=127.0.0.1
PORT=3333

# --- Workspace access ---
# Comma-separated list of allowed workspace root directories.
# CTM_ALLOWED_ROOTS=C:\Projects,/home/me/projects

# --- Access mode ---
# review: allow only safe commands (git status/diff, ls, npm test, etc.)
# full: allow arbitrary shell commands (use at your own risk)
# CTM_ACCESS_MODE=review

# --- File read / output caps ---
# CTM_MAX_READ_BYTES=200000
# CTM_MAX_OUTPUT_BYTES=200000

# --- Web tools (optional, set CTM_WEB_TOOLS=1 to enable) ---
# CTM_WEB_TOOLS=1
# CTM_SEARCH_PROVIDER=searxng
# CTM_SEARXNG_URL=http://127.0.0.1:8080
# CTM_WEB_MAX_BYTES=200000
# CTM_WEB_TIMEOUT_MS=15000

# --- SQLite tools (optional, set CTM_SQLITE_TOOLS=1 to enable) ---
# CTM_SQLITE_TOOLS=1
# CTM_SQLITE_ALLOWED_DBS=C:\path\to\db.sqlite,/home/me/data.db
# CTM_SQLITE_MAX_ROWS=100
