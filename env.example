# Local MCP server
HOST=127.0.0.1
PORT=3333
CTM_ACCESS_MODE=review
CTM_ALLOWED_ROOTS=C:\\Projects
CTM_MAX_READ_BYTES=200000
CTM_MAX_OUTPUT_BYTES=200000

# Optional: comma-separated deny rules. Defaults already block common secret paths.
# CTM_DENY_GLOBS=**/.env,**/.env.*,**/id_rsa,**/id_ed25519,**/*token*,**/*secret*,**/AppData/**,**/.git/config

# Optional Windows helpers
# CTM_NPM_CACHE=E:\\npm-cache
# OPENCLAW_NODE_BIN=C:\\Tools\\openclaw\\runtime\\node

# OpenAI Secure MCP Tunnel helper script
# Set this in your shell instead of committing it.
# CONTROL_PLANE_API_KEY=YOUR_RUNTIME_KEY_HERE
# TUNNEL_CLIENT=C:\\path\\to\\tunnel-client.exe
# PROFILE=codex_MCP
# HEALTH_ADDR=127.0.0.1:8081
# PROXY_URL=http://127.0.0.1:10808

# Optional web tools (default: disabled)
# CTM_WEB_TOOLS=1
# CTM_SEARCH_PROVIDER=searxng
# CTM_SEARXNG_URL=http://127.0.0.1:8888
# CTM_WEB_MAX_BYTES=200000
# CTM_WEB_TIMEOUT_MS=15000

# Optional SQLite tools (default: disabled)
# Only databases explicitly listed in CTM_SQLITE_ALLOWED_DBS can be opened.
# Requires Node.js with node:sqlite support, such as Node 24+.
# CTM_SQLITE_TOOLS=1
# CTM_SQLITE_ALLOWED_DBS=E:\\openclaw\\.openclaw\\state\\openclaw.sqlite
# CTM_SQLITE_MAX_ROWS=100

# Optional OpenClaw cron helpers, backed by the allowed SQLite DB above.
# CTM_CRON_DB_PATH=E:\\openclaw\\.openclaw\\state\\openclaw.sqlite
# CTM_CRON_STORE_KEY=E:\\openclaw\\.openclaw\\cron\\jobs.json
