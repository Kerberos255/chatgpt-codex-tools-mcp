# Local MCP server
HOST=127.0.0.1
PORT=3333
CTM_ACCESS_MODE=review
CTM_ALLOWED_ROOTS=C:\\Projects
CTM_MAX_READ_BYTES=200000
CTM_MAX_OUTPUT_BYTES=200000

# Optional: comma-separated deny rules. Defaults already block common secret paths.
# CTM_DENY_GLOBS=**/.env,**/.env.*,**/id_rsa,**/id_ed25519,**/*token*,**/*secret*,**/AppData/**,**/.git/config

# Optional Windows helpers
# CTM_NPM_CACHE=E:\\npm-cache
# OPENCLAW_NODE_BIN=C:\\Tools\\openclaw\\runtime\\node

# OpenAI Secure MCP Tunnel helper script
# Set this in your shell instead of committing it.
# CONTROL_PLANE_API_KEY=sk-...
# TUNNEL_CLIENT=C:\\path\\to\\tunnel-client.exe
# PROFILE=codex_MCP
# HEALTH_ADDR=127.0.0.1:8081
# PROXY_URL=http://127.0.0.1:10808
